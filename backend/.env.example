# App
APP_PORT=3001
APP_ENV=development
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://hosting_nepal:password@localhost:5432/hosting_nepal

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ResellerClub API
RESELLERCLUB_AUTH_USERID=
RESELLERCLUB_API_KEY=
RESELLERCLUB_BASE_URL=https://httpapi.com/api
RESELLERCLUB_SANDBOX_URL=https://test.httpapi.com/api
RESELLERCLUB_USE_SANDBOX=true

# Payment Gateways
KHALTI_SECRET_KEY=
KHALTI_PUBLIC_KEY=
KHALTI_BASE_URL=https://khalti.com/api/v2
ESEWA_MERCHANT_CODE=
ESEWA_BASE_URL=https://epay.esewa.com.np/api/epay/main/v2

# Email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@hostingnepal.com

# SMS
SPARROW_SMS_TOKEN=
SPARROW_SMS_FROM=HostingNepal

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Blog Auto-Generation (Gemini free tier)
GEMINI_API_KEY=
UNSPLASH_ACCESS_KEY=
BLOG_AUTOGEN_ENABLED=false
BLOG_AUTOGEN_MODEL=gemini-2.5-flash
BLOG_AUTOGEN_BOT_EMAIL=content-bot@hostingnepals.com

# Cloudflare R2 Object Storage (for blog images, author avatars)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
